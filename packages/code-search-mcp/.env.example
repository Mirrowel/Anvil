# ── Server ────────────────────────────────────────────────────────────
CODE_SEARCH_PORT=3100
CODE_SEARCH_TRANSPORT=streamable-http

# ── Auth ──────────────────────────────────────────────────────────────
# api-key | jwt | none
CODE_SEARCH_AUTH_MODE=api-key
# Comma-separated API keys (generate with: openssl rand -hex 32)
CODE_SEARCH_AUTH_API_KEYS=
# For JWT mode:
# CODE_SEARCH_AUTH_JWT_SECRET=
# CODE_SEARCH_AUTH_JWT_ISSUER=code-search-mcp

# ── Embedding ─────────────────────────────────────────────────────────
# auto | codestral | openai | voyage | ollama | gemini | custom
CODE_SEARCH_EMBEDDING_PROVIDER=auto
# Unified API key (maps to provider-specific env var automatically)
CODE_SEARCH_EMBEDDING_API_KEY=
# For custom/openai-compatible embedding provider:
# CODE_SEARCH_EMBEDDING_BASE_URL=https://api.your-provider.com
# CODE_SEARCH_EMBEDDING_MODEL=your-model-name
# Tune for provider rate limits. Mistral free tier is often 1 request/sec.
# CODE_SEARCH_EMBEDDING_BATCH_SIZE=50
# CODE_SEARCH_EMBEDDING_BATCH_DELAY_MS=1100
# CODE_SEARCH_EMBEDDING_MAX_RETRIES=6

# ── Reranker ──────────────────────────────────────────────────────────
# ollama | cohere | nvidia | voyage | custom | none
CODE_SEARCH_RERANKER_PROVIDER=ollama
# Native reranker model, e.g. rerank-v4.0-pro or nv-rerank-qa-mistral-4b:1
# CODE_SEARCH_RERANKER_MODEL=
# For custom/openai-compatible reranker (any LLM with chat completions API):
# CODE_SEARCH_RERANKER_BASE_URL=https://api.your-provider.com
# CODE_SEARCH_RERANKER_MODEL=your-model-name
# CODE_SEARCH_RERANKER_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Repos ─────────────────────────────────────────────────────────────
# Path to local repos directory (mounted read-only into container)
REPOS_PATH=./repos
